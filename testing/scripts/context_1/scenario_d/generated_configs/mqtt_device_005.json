{
  "gatewayDeviceId": "mqtt_device_005",
  "adapter": "mqtt",
  "queuing": {
    "retryIntervalSeconds": 5,
    "maxTimeToLiveSeconds": 40
  },
  "connection": {
    "qos": 1,
    "keepAliveInterval": 30,
    "connectionTimeout": 10,
    "cleanSession": true,
    "reconnectDelay": 5
  },
  "subscriptions": [
    {
      "topic": "devices/mqtt_device_005/telemetry",
      "forwardToBackend": true
    },
    {
      "topic": "devices/mqtt_device_005/status",
      "forwardToBackend": true
    }
  ],
  "commands": {
    "setPower": {
      "name": "setPower",
      "topic": "devices/mqtt_device_005/commands",
      "responseTopic": "devices/mqtt_device_005/telemetry",
      "timeouts": {
        "response": 10
      },
      "payloadTemplate": {
        "type": "setPower",
        "operation": {
          "dispatchPower": {
            "current": null
          },
          "chargeToState": {
            "rampRate": null
          }
        },
        "startAt": null,
        "endAt": null,
        "flags": {
          "dryRun": null
        }
      },
      "mappings": {
        "current": "operation.dispatchPower.current",
        "dryRun": "flags.dryRun",
        "rampRate": "operation.chargeToState.rampRate",
        "startAt": "startAt",
        "endAt": "endAt"
      },
      "cleanup": {
        "removeNulls": true,
        "removeEmpty": false,
        "emptyObjectToNull": false
      }
    },
    "setMode": {
      "name": "setMode",
      "topic": "devices/mqtt_device_005/commands",
      "responseTopic": "devices/mqtt_device_005/telemetry",
