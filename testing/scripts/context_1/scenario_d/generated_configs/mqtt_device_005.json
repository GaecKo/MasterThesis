        "response": 10
      },
      "payloadTemplate": {
        "type": "setMode",
        "operation": {
          "chargeToState": {
            "chargeMode": null,
            "percentage": null
          },
          "dispatchPower": {
            "frequency": null,
            "reactivePower": null,
            "current": null,
            "activePower": null
          },
          "deliverFCR": {
            "maxRate": null
          }
        },
        "startAt": null,
        "endAt": null,
        "metadata": {
          "correlationId": null,
          "reason": null
        },
        "context": {
          "environmentTag": null
        },
        "flags": {
          "auditTrailEnabled": null,
          "dryRun": null
        },
        "duration": null
      },
      "mappings": {
        "correlationId": "metadata.correlationId",
        "chargeMode": "operation.chargeToState.chargeMode",
        "frequency": "operation.dispatchPower.frequency",
        "percentage": "operation.chargeToState.percentage",
        "reactivePower": "operation.dispatchPower.reactivePower",
        "environmentTag": "context.environmentTag",
        "reason": "metadata.reason",
        "auditTrailEnabled": "flags.auditTrailEnabled",
        "current": "operation.dispatchPower.current",
        "duration": "duration",
        "activePower": "operation.dispatchPower.activePower",
        "maxRate": "operation.deliverFCR.maxRate",
        "dryRun": "flags.dryRun",
        "startAt": "startAt",
        "endAt": "endAt"
      },
      "cleanup": {
        "removeNulls": true,
        "removeEmpty": false,
        "emptyObjectToNull": false
      }
    },
    "setChargeTarget": {
      "name": "setChargeTarget",
      "topic": "devices/mqtt_device_005/commands",
      "responseTopic": "devices/mqtt_device_005/telemetry",
      "timeouts": {
        "response": 10
      },
      "payloadTemplate": {
        "type": "setChargeTarget",
        "operation": {},
