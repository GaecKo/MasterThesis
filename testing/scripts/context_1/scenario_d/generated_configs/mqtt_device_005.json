{
  "gatewayDeviceId": "mqtt_device_005",
  "adapter": "mqtt",
  "queuing": {
    "retryIntervalSeconds": 5,
    "maxTimeToLiveSeconds": 40
  },
  "connection": {
    "qos": 1,
    "keepAliveInterval": 30,
    "connectionTimeout": 10,
    "cleanSession": true,
    "reconnectDelay": 5
  },
  "subscriptions": [
    {
      "topic": "devices/mqtt_device_005/telemetry",
      "forwardToBackend": true
    },
    {
      "topic": "devices/mqtt_device_005/status",
      "forwardToBackend": true
    }
  ],
  "commands": {
    "setPower": {
      "name": "setPower",
      "topic": "devices/mqtt_device_005/commands",
      "responseTopic": "devices/mqtt_device_005/telemetry",
      "timeouts": {
        "response": 10
      },
      "payloadTemplate": {
        "type": "setPower",
        "operation": {
          "chargeToState": {
            "percentage": null
          },
          "deliverFCR": {
            "droopSetting": null
          },
          "dispatchPower": {
            "activePower": null,
            "current": null
          }
        },
        "startAt": null,
        "endAt": null,
        "context": {
          "regionCode": null
        },
        "flags": {
          "dryRun": null,
          "notifyOnComplete": null
        },
        "metadata": {
          "priority": null
        },
        "duration": null
      },
      "mappings": {
        "percentage": "operation.chargeToState.percentage",
        "regionCode": "context.regionCode",
        "droopSetting": "operation.deliverFCR.droopSetting",
        "activePower": "operation.dispatchPower.activePower",
        "dryRun": "flags.dryRun",
        "priority": "metadata.priority",
        "current": "operation.dispatchPower.current",
        "notifyOnComplete": "flags.notifyOnComplete",
        "duration": "duration",
        "startAt": "startAt",
        "endAt": "endAt"
      },
      "cleanup": {
        "removeNulls": true,
        "removeEmpty": false,
        "emptyObjectToNull": true
      }
    },
    "setMode": {
      "name": "setMode",
      "topic": "devices/mqtt_device_005/commands",
      "responseTopic": "devices/mqtt_device_005/telemetry",
      "timeouts": {
        "response": 10
      },
      "payloadTemplate": {
        "type": "setMode",
        "operation": {
          "chargeToState": {
            "maxCurrent": null,
            "targetSoC": null,
            "chargeMode": null
          },
          "deliverFCR": {
            "maxRate": null,
            "droopSetting": null
          }
        },
        "startAt": null,
        "endAt": null,
        "metadata": {
          "source": null
        },
        "flags": {
          "forceExecution": null
        }
      },
      "mappings": {
        "maxCurrent": "operation.chargeToState.maxCurrent",
        "maxRate": "operation.deliverFCR.maxRate",
        "targetSoC": "operation.chargeToState.targetSoC",
        "source": "metadata.source",
        "chargeMode": "operation.chargeToState.chargeMode",
        "forceExecution": "flags.forceExecution",
        "droopSetting": "operation.deliverFCR.droopSetting",
        "startAt": "startAt",
        "endAt": "endAt"
      },
      "cleanup": {
        "removeNulls": true,
        "removeEmpty": true,
        "emptyObjectToNull": false
      }
    },
    "setChargeTarget": {
      "name": "setChargeTarget",
      "topic": "devices/mqtt_device_005/commands",
