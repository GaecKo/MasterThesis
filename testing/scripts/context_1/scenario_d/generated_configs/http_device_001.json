{
  "gatewayDeviceId": "http_device_001",
  "adapter": "http",
  "queuing": {
    "retryIntervalSeconds": 5,
    "maxTimeToLiveSeconds": 40
  },
  "commands": {
    "setBatteryOperation": {
      "name": "setBatteryOperation",
      "endpoint": "https://nuc8-pc.local:8443/v2/schedule/",
      "method": "POST",
      "timeouts": {
        "connect": 2,
        "request": 10
      },
      "payloadTemplate": {
        "schedule": [
          {
            "type": "setBatteryOperation",
            "operation": {
              "chargeToState": {
                "rampRate": null,
                "targetSoC": null
              }
            },
            "startAt": null,
            "endAt": null
          }
        ],
        "assetIdentifiers": null,
        "flags": {
          "auditTrailEnabled": null
        }
      },
      "mappings": {
        "rampRate": "schedule[0].operation.chargeToState.rampRate",
        "auditTrailEnabled": "flags.auditTrailEnabled",
        "targetSoC": "schedule[0].operation.chargeToState.targetSoC",
        "startAt": "schedule[0].startAt",
        "endAt": "schedule[0].endAt"
      },
      "cleanup": {
        "emptyObjectToNull": true,
        "removeNulls": true,
        "removeEmpty": true
      }
    },
    "setChargeTarget": {
