                "minRate": null
              }
            },
            "startAt": null,
            "endAt": null
          }
        ],
        "assetIdentifiers": null,
        "metadata": {
          "reason": null,
          "requestVersion": null
        }
      },
      "mappings": {
        "reason": "metadata.reason",
        "reactivePower": "schedule[0].operation.dispatchPower.reactivePower",
        "requestVersion": "metadata.requestVersion",
        "minRate": "schedule[0].operation.deliverFCR.minRate",
        "startAt": "schedule[0].startAt",
        "endAt": "schedule[0].endAt"
      },
      "cleanup": {
        "emptyObjectToNull": true,
        "removeNulls": false,
        "removeEmpty": true
      }
    },
