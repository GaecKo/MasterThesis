              }
            },
            "startAt": null,
            "endAt": null
          }
        ],
        "assetIdentifiers": null,
        "metadata": {
          "source": null
        },
        "context": {
          "regionCode": null,
          "siteId": null
        }
      },
      "mappings": {
        "source": "metadata.source",
