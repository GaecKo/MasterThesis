            "endAt": null
          }
        ],
        "assetIdentifiers": null,
        "metadata": {
          "priority": null,
          "source": null
        }
      },
      "mappings": {
        "activePower": "schedule[0].operation.dispatchPower.activePower",
        "priority": "metadata.priority",
        "source": "metadata.source",
        "startAt": "schedule[0].startAt",
        "endAt": "schedule[0].endAt"
      },
      "cleanup": {
        "emptyObjectToNull": true,
        "removeNulls": false,
        "removeEmpty": true
      }
    },
