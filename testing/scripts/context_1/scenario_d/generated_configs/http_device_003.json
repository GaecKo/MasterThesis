{
  "gatewayDeviceId": "http_device_003",
  "adapter": "http",
  "queuing": {
    "retryIntervalSeconds": 5,
    "maxTimeToLiveSeconds": 40
  },
  "commands": {
    "setBatteryOperation": {
      "name": "setBatteryOperation",
      "endpoint": "https://nuc8-pc.local:8445/v2/schedule/",
      "method": "POST",
      "timeouts": {
        "connect": 2,
        "request": 10
      },
      "payloadTemplate": {
        "schedule": [
          {
            "type": "setBatteryOperation",
            "operation": {
              "dispatchPower": {
                "reactivePower": null,
                "apparentPower": null,
                "activePower": null
              }
            },
            "startAt": null,
            "endAt": null
          }
        ],
        "assetIdentifiers": null,
        "context": {
          "timezone": null
        }
      },
      "mappings": {
        "reactivePower": "schedule[0].operation.dispatchPower.reactivePower",
        "timezone": "context.timezone",
        "apparentPower": "schedule[0].operation.dispatchPower.apparentPower",
        "activePower": "schedule[0].operation.dispatchPower.activePower",
        "startAt": "schedule[0].startAt",
        "endAt": "schedule[0].endAt"
      },
      "cleanup": {
        "emptyObjectToNull": false,
        "removeNulls": true,
        "removeEmpty": true
      }
    },
    "setChargeTarget": {
