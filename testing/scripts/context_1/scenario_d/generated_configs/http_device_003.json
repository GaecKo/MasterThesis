                "targetSoC": null
              },
              "deliverFCR": {
                "maxRate": null
              }
            },
            "startAt": null,
            "endAt": null
          }
        ],
        "assetIdentifiers": null,
        "context": {
          "tenantId": null,
          "siteId": null
        },
        "metadata": {
          "requestedBy": null
