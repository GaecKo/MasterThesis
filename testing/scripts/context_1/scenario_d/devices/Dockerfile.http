FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package.json ./
RUN npm install --omit=dev

# Copy device script
COPY http_device.js ./

# Copy certs — place device.crt and device.key in this directory before building
COPY device.crt /certs/device.crt
COPY device.key /certs/device.key

RUN chmod 644 /certs/device.crt \
 && chmod 600 /certs/device.key

# HTTPS_PORT is set per-container by launch_devices.sh so each device
# listens on a different port and can be targeted independently.
ENV DEVICE_ID=http_device_001 \
    HTTPS_PORT=8443 \
    HTTP_PORT=8000 \
    APISIX_IP=nuc4-pc.local \
    HTTP_DEVICE_IP=nuc8-pc.local \
    INTERVAL_MS=60000 \
    CERT_PATH=/certs/device.crt \
    KEY_PATH=/certs/device.key

# Expose both ports; the actual HTTPS port is overridden at runtime via env var
EXPOSE 8000
EXPOSE 8443

CMD ["node", "http_device.js"]