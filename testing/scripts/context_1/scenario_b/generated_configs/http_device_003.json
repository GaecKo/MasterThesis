        "connect": 2,
        "request": 10
      },
      "payloadTemplate": {
        "schedule": [
          {
            "type": "setBatteryOperation",
            "operation": {
              "dispatchPower": {
                "voltage": null
              }
            },
            "startAt": null,
            "endAt": null,
            "duration": null
          }
        ],
        "assetIdentifiers": null,
        "metadata": {
          "priority": null
        },
        "context": {
          "tenantId": null
        }
      },
      "mappings": {
        "priority": "metadata.priority",
        "tenantId": "context.tenantId",
        "voltage": "schedule[0].operation.dispatchPower.voltage",
        "duration": "schedule[0].duration",
        "startAt": "schedule[0].startAt",
        "endAt": "schedule[0].endAt"
      },
      "cleanup": {
        "emptyObjectToNull": true,
        "removeNulls": true,
        "removeEmpty": false
      }
    },
