FROM node:20-alpine

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev

COPY mqtt_device.js ./

# device.crt / device.key are not strictly needed by MQTT devices (no mTLS),
# but backend.crt is required to verify the Mosquitto broker's TLS certificate.
COPY backend.crt /certs/backend.crt

RUN chmod 644 /certs/backend.crt

ENV DEVICE_ID=mqtt_device_001 \
    BROKER_URL=mqtts://nuc1-pc.local:8883 \
    INTERVAL_MS=60000 \
    CA_CERT_PATH=/certs/backend.crt

CMD ["node", "mqtt_device.js"]